# ============================================================
# Server Levels+ Discord Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- REQUIRED ------------------------------------------------
# Your Discord bot token (from https://discord.com/developers)
DISCORD_TOKEN=your-bot-token-here

# Your Discord Application ID
APPLICATION_ID=your-application-id-here

# ---- OPTIONAL ------------------------------------------------
# Set to a specific guild ID for faster slash-command sync during development.
# Remove or leave empty to sync globally (can take up to 1 hour).
# GUILD_ID=your-guild-id

# ---- DATABASE -----------------------------------------------
# SQLite is used by default. To use PostgreSQL, set DATABASE_URL.
DATABASE_PATH=data/bot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/serverlevels

# ---- XP SETTINGS --------------------------------------------
XP_PER_MESSAGE_MIN=15
XP_PER_MESSAGE_MAX=25
XP_COOLDOWN_SECONDS=60
XP_PER_VOICE_MINUTE=10
DAILY_XP_CAP=5000
MAX_LEVEL=100

# ---- ECONOMY ------------------------------------------------
COINS_PER_MESSAGE=5
COINS_PER_LEVEL_UP=100
DAILY_COINS_MIN=100
DAILY_COINS_MAX=500

# ---- DASHBOARD ----------------------------------------------
# Port for the bot's internal dashboard API
DASHBOARD_API_PORT=8000
# The URL of your deployed dashboard website (for OAuth redirects)
DASHBOARD_URL=http://localhost:3000
# Secret key shared between bot and dashboard API
API_SECRET=change-me-in-production-random-string

# ---- DISCORD OAUTH (for dashboard login) --------------------
DISCORD_CLIENT_ID=your-oauth-client-id
DISCORD_CLIENT_SECRET=your-oauth-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---- LOGGING ------------------------------------------------
LOG_LEVEL=INFO
# LOG_CHANNEL_ID=your-log-channel-id

# ---- TOP.GG (optional, for bot listing) --------------------
# TOPGG_TOKEN=your-topgg-token
# TOPGG_WEBHOOK_AUTH=your-webhook-auth-password
